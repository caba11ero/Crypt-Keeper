{
  "name": "cryptkeeper",
  "version": "1.0.0",
  "description": "Secure Client-Side Encrypted Notes Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack:win": "electron-builder --win --publish never",
    "pack:linux": "electron-builder --linux deb AppImage --publish never",
    "pack:all": "electron-builder --win --linux deb AppImage --publish never"
  },
  "keywords": [
    "encryption",
    "notes",
    "markdown",
    "security"
  ],
  "author": "caba11ero <avedp@proton.me>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.6"
  },
  "build": {
    "appId": "com.cryptkeeper.app",
    "productName": "CryptKeeper",
    "toolsets": {
      "appimage": "1.0.3"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "icon": "icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "style.css",
      "crypto.js",
      "app.js",
      "main.js",
      "icon.png"
    ]
  }
}
